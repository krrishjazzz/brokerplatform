# Supabase — copy from Dashboard > Connect > ORMs > Prisma (match your region, e.g. aws-1-ap-southeast-1)
DATABASE_URL="postgresql://postgres.[PROJECT-REF]:[PASSWORD]@aws-1-ap-southeast-1.pooler.supabase.com:6543/postgres?pgbouncer=true"
DIRECT_URL="postgresql://postgres.[PROJECT-REF]:[PASSWORD]@aws-1-ap-southeast-1.pooler.supabase.com:5432/postgres"

# Local Docker: npm run db:up
# DATABASE_URL="postgresql://krishjazz:krishjazz@localhost:5432/krishjazz?schema=public"
# DIRECT_URL="postgresql://krishjazz:krishjazz@localhost:5432/krishjazz?schema=public"

JWT_SECRET="change-me-in-production"

# Optional
# MOCK_OTP=true
# NEXT_PUBLIC_GOOGLE_MAPS_API_KEY=
# NEXT_PUBLIC_PLATFORM_PHONE=
